# Cloudflare Worker Secrets
# Set these using: npx wrangler secret put <SECRET_NAME>

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# GitHub API (needs admin:repo_hook scope for webhook creation)
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_OWNER=your_github_username

# GitHub Webhook Secret (generate with: openssl rand -hex 32)
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# Grok AI
GROK_API_KEY=your_grok_api_key

# X (Twitter) API
X_API_KEY=your_x_api_key
X_API_SECRET=your_x_api_secret
X_ACCESS_TOKEN=your_x_access_token
X_ACCESS_SECRET=your_x_access_token_secret

# Admin Secret for protected endpoints (/setup, /migrate)
# Generate with: openssl rand -hex 32
# Required for security hardening
ADMIN_SECRET=your_admin_secret
