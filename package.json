{
  "name": "commit-content-tracker",
  "version": "1.0.0",
  "description": "AI-powered content generation from GitHub commits to X threads",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "generate": "tsx src/workflows/generate-content.ts",
    "publish-drafts": "tsx src/workflows/publish-drafts.ts",
    "telegram": "tsx src/workflows/telegram-handler.ts"
  },
  "keywords": [
    "ai",
    "twitter",
    "x",
    "github",
    "automation",
    "content"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "winston": "^3.17.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
